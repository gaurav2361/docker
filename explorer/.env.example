# Timezone
TZ=Asia/Kolkata

# User/Group IDs
PUID=1000
PGID=1000

# Network Configuration
# Use your local IP (192.168.x.x) for local-only setup
# Use your domain (media.yourdomain.com) for external setup
SERVER_IP_OR_DOMAIN=192.168.1.X

# NextExplorer / OIDC
OIDC_CLIENT_ID=nextexplorer
OIDC_CLIENT_SECRET=nextexplorer_secret

# Immich Database
IMMICH_DB_PASSWORD=change_me
IMMICH_DB_USERNAME=immich
IMMICH_DB_NAME=immich

# PostgreSQL (Immich)
POSTGRES_PASSWORD=change_me
POSTGRES_USER=immich
POSTGRES_DB=immich
