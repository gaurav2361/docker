# Timezone
TZ=Asia/Kolkata

# User/Group IDs
PUID=1000
PGID=1000

# Network Configuration
LOCAL_IP=192.168.1.XX
DOMAIN=media.marketingcompany.com
PRIMARY_BASE_URL=http://${LOCAL_IP}

# LLDAP Identity Configuration
LDAP_BASE_DN=dc=marketing,dc=com
LDAP_ADMIN_PASSWORD=change_me_admin_pass
LLDAP_SEED=random_string_for_security

# Google OAuth (Sign-in with Google)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# SMTP Email (For Notifications/Invites)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

# NextExplorer SSO
OIDC_CLIENT_ID=nextexplorer
OIDC_CLIENT_SECRET=nextexplorer_secret

# Immich Database
IMMICH_DB_USERNAME=immich
IMMICH_DB_PASSWORD=change_me
IMMICH_DB_NAME=immich

# PostgreSQL (Immich)
POSTGRES_USER=immich
POSTGRES_PASSWORD=change_me
POSTGRES_DB=immich
