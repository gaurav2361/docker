# Timezone
TZ=Asia/Kolkata

# User/Group IDs
PUID=1000
PGID=1000

# Network Configuration
# 1. Your server's static local IP
LOCAL_IP=192.168.1.XX
# 2. Your registered domain name
DOMAIN=media.yourdomain.com

# Active Identity (Which one the apps use for OIDC/Links)
# Set to http://${LOCAL_IP} for local-only
# Set to https://${DOMAIN} for external/domain access
PRIMARY_BASE_URL=http://${LOCAL_IP}

# NextExplorer SSO
OIDC_CLIENT_ID=nextexplorer
OIDC_CLIENT_SECRET=nextexplorer_secret

# Immich Database
IMMICH_DB_USERNAME=immich
IMMICH_DB_PASSWORD=change_me
IMMICH_DB_NAME=immich

# PostgreSQL (Immich)
POSTGRES_USER=immich
POSTGRES_PASSWORD=change_me
POSTGRES_DB=immich
