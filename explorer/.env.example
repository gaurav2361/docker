# Timezone
TZ=Asia/Kolkata

# User/Group IDs
PUID=1000
PGID=1000

# Network Configuration
LOCAL_IP=192.168.1.XX
DOMAIN=media.marketingcompany.com
PRIMARY_BASE_URL=http://${LOCAL_IP}

# LLDAP Identity Configuration
LDAP_BASE_DN=dc=marketing,dc=com
LDAP_ADMIN_PASSWORD=change_me_admin_pass
LLDAP_SEED=random_string_for_security

# NextExplorer SSO
OIDC_CLIENT_ID=nextexplorer
OIDC_CLIENT_SECRET=nextexplorer_secret

# Immich Database
IMMICH_DB_USERNAME=immich
IMMICH_DB_PASSWORD=change_me
IMMICH_DB_NAME=immich

# PostgreSQL (Immich)
POSTGRES_USER=immich
POSTGRES_PASSWORD=change_me
POSTGRES_DB=immich
