# General UID/GID and Timezone
TZ=Asia/Kolkata
PUID=1000
PGID=1000

# Input your VPN provider and type here
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard

# Enable automatic port forwarding for ProtonVPN (crucial for qBittorrent)
PORT_FORWARDING=on

# Copy all these variables from your generated configuration file
WIREGUARD_PUBLIC_KEY=key
WIREGUARD_PRIVATE_KEY=key
WIREGUARD_PRESHARED_KEY=key
WIREGUARD_ADDRESSES=ip

# ProtonVPN requires you to specify a server country or name.
# Make sure to pick a country that allows P2P/Torrenting (like Switzerland, Netherlands, etc.)
SERVER_COUNTRIES=Switzerland

# Health check duration
HEALTH_VPN_DURATION_INITIAL=120s
